# Deployer (required for live networks)
DEPLOYER_PRIVATE_KEY=

# Arbitrum RPC (optional — defaults in hardhat.config.js)
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARB_RPC_URL=https://arb1.arbitrum.io/rpc

# Fee token for machine registration, contract setup, transfer fees
# Leave unset on local Hardhat to auto-deploy MockFeeToken
FEE_TOKEN_ADDRESS=

# After deploy — from log "ClaimIssuer ONCHAINID (KYC): 0x..."
# Or read from deployments/deployment-<chainId>.json
CLAIM_ISSUER_ADDRESS=
ID_FACTORY_ADDRESS=
ARB_RWA_NFT_ADDRESS=
