# Copy to packages/hardhat/.env before deploying to Arbitrum Sepolia.

# Alchemy key for RPC (optional — a shared dev key is bundled in hardhat.config.ts)
ALCHEMY_API_KEY=

# Arbiscan / Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Deployer key (required for live networks)
# Stored in .secrets/deployer.keystore.json (do not put full JSON on one .env line; commas break parsing)
DEPLOYER_KEYSTORE_FILE=.secrets/deployer.keystore.json

# Optional: plain key skips the password prompt (never commit a real key)
# DEPLOYER_PRIVATE_KEY=0x...

# Optional: non-interactive decrypt (no password prompt in yarn bootstrap / yarn seed:demo-assets)
# DEPLOY_PASSWORD=your-encrypt-password

# Optional RPC override (defaults to Alchemy arb-sepolia)
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Fee token for machine registration, contract setup, and transfer fees.
# Leave unset to deploy MockFeeToken (fine for first testnet smoke test).
# Circle USDC on Arbitrum Sepolia:
# FEE_TOKEN_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# Optional overrides — leave unset; scripts read deployments/<network>/*.json first.
# Stale CLAIM_ISSUER_ADDRESS / ID_FACTORY_ADDRESS after redeploy causes issue-claims failures.
# CLAIM_ISSUER_ADDRESS=
# ID_FACTORY_ADDRESS=

# Test participants (Arbitrum Sepolia) — addresses shown in /rwa wallet hints
ALICE_ADDRESS=0xdEBC58A3CE140Ef84E5757013c1998FdAfDB44D6
BOB_ADDRESS=0xc67c0d1d4e12D838f3ed2fC6241D8e65Dfb3100B
CHARLIE_ADDRESS=0xe62803A1A219Be5f0D437ed9F84F2e4CDc8A3Ca1

# Private keys for full demo bootstrap (KYC + CNFT signing + demo NFTs) — never commit real keys
# ALICE_PRIVATE_KEY=0x...
# BOB_PRIVATE_KEY=0x...
# CHARLIE_PRIVATE_KEY=0x...

# Pin demo agreement JSON to IPFS (yarn pin:demo-agreement)
# Create key at https://app.pinata.cloud/developers/keys with pinByHash and/or pinFileToIPFS enabled
# PINATA_JWT=
# NEXT_PUBLIC_GATEWAY_URL=your-subdomain.mypinata.cloud

# Skip bootstrap demo NFT seeding only
# SKIP_DEMO_ASSETS=true

# Local only: skip entire debug bootstrap
# SKIP_DEBUG_BOOTSTRAP=true
